{
    "name": "management-app",
    "version": "0.0.1",
    "private": true,
    "description": "The SafeInsights management app serves as an interface for researchers to submit and reviewers to approve study proposals.",
    "license": "AGPL-3.0-or-later",
    "author": "Nathan Stitt",
    "main": "index.js",
    "type": "module",
    "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "scripts": {
        "build:app": "./bin/build-app",
        "build:editor": "./services/editor/build",
        "ci:server": "./bin/ci-server",
        "dev": "env -u AWS_PROFILE next dev -p 4000",
        "dev:local": "concurrently --kill-others-on-fail --kill-signal SIGKILL pnpm:dev pnpm:s3:local pnpm:editor:local",
        "editor:local": "node --env-file=.env services/editor/server.ts",
        "hocuspocus": "node services/editor/server.ts",
        "s3:local": "./bin/local-seaweedfs",
        "prepare": "panda codegen",
        "build": "next build",
        "ladle": "PANDA_LOG_LEVEL=silent ladle serve",
        "ladle:build": "PANDA_LOG_LEVEL=silent ladle build --outDir .ladle/dist",
        "ladle:build:standalone": "LADLE_STANDALONE=1 PANDA_LOG_LEVEL=silent ladle build --outDir .ladle/dist-standalone",
        "ladle:build:pages": "PANDA_LOG_LEVEL=silent ladle build --outDir .ladle/dist --base ${LADLE_BASE_PATH:-/}",
        "db:migrate": "./bin/migrate-dev-db",
        "create-admin-user": "tsx bin/create-admin-user.ts",
        "start": "next start",
        "deploy": "tsx bin/deploy.ts",
        "lint": "eslint . && prettier --check --log-level warn .",
        "validate-actions": "tsx tests/validate-actions.ts",
        "lint:fix": "eslint --fix . && prettier --write --log-level warn .",
        "pre:push": "concurrently --kill-others-on-fail 'pnpm:lint:fix' 'pnpm:typecheck' 'pnpm:validate-actions'",
        "typecheck": "next typegen && tsc --noEmit --skipLibCheck",
        "update-db-types": "kysely-codegen --camel-case --out-file src/database/types.ts",
        "checks": "concurrently 'pnpm:typecheck' 'pnpm:lint' 'pnpm:validate-actions'",
        "test:e2e": "playwright test",
        "test:e2e:debug": "playwright test --ui --headed --debug",
        "test:unit": "vitest",
        "test": "concurrently 'pnpm:test:*'",
        "test:coverage": "tsx tests/merged-coverage.ts",
        "pre:commit": "pnpm exec lint-staged",
        "update-all-packages": "pnpm dlx npm-check-updates -u"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.95.2",
        "@aws-sdk/client-codebuild": "^3.893.0",
        "@aws-sdk/client-ecr": "^3.893.0",
        "@aws-sdk/client-glue": "^3.893.0",
        "@aws-sdk/client-s3": "^3.893.0",
        "@aws-sdk/client-secrets-manager": "^3.893.0",
        "@aws-sdk/client-sts": "^3.893.0",
        "@aws-sdk/credential-providers": "^3.893.0",
        "@aws-sdk/lib-storage": "^3.893.0",
        "@aws-sdk/rds-signer": "^3.893.0",
        "@aws-sdk/s3-presigned-post": "^3.893.0",
        "@aws-sdk/s3-request-presigner": "^3.893.0",
        "@casl/ability": "^6.8.0",
        "@clerk/backend": "^2.33.4",
        "@clerk/nextjs": "^6.39.4",
        "@clerk/types": "^4.101.24",
        "@faker-js/faker": "^10.3.0",
        "@hocuspocus/provider": "^3.4.4",
        "@hocuspocus/server": "^3.4.4",
        "@lexical/headless": "^0.41.0",
        "@lexical/link": "^0.41.0",
        "@lexical/list": "^0.41.0",
        "@lexical/react": "^0.41.0",
        "@lexical/utils": "^0.41.0",
        "@lexical/yjs": "^0.41.0",
        "@mantine/core": "^8.3",
        "@mantine/dropzone": "^8.3",
        "@mantine/form": "^8.3",
        "@mantine/hooks": "^8.3",
        "@mantine/modals": "^8.3",
        "@mantine/notifications": "^8.3",
        "@phosphor-icons/react": "^2.1.10",
        "@sentry/nextjs": "^10.41.0",
        "@swc/helpers": "0.5.15",
        "@tanstack/react-query": "^5.90.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/papaparse": "^5.5.2",
        "@types/pg": "^8.15.6",
        "aws-iam-policy-types": "^1.0.2",
        "child_process": "^1.0.2",
        "clsx": "^2.1.1",
        "commander": "^14.0.3",
        "dayjs": "^1.11.19",
        "debug": "^4.4.3",
        "eventsource-parser": "^3.0.6",
        "highlight.js": "^11.11.1",
        "jsonwebtoken": "^9.0.3",
        "jws": "^4.0.1",
        "kysely": "^0.28.12",
        "kysely-ctl": "^0.20.0",
        "lexical": "^0.41.0",
        "libphonenumber-js": "^1.12.38",
        "mailgun.js": "^12.7.0",
        "mantine-datatable": "^8.3.13",
        "mantine-form-zod-resolver": "^1.3.0",
        "next": "^16.2.0",
        "next-swagger-doc": "^0.4.1",
        "papaparse": "^5.5.3",
        "pg": "^8.19.0",
        "qrcode.react": "^4.2.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-icons": "^5.5.0",
        "react-phone-number-input": "^3.4.16",
        "remeda": "^2.33.6",
        "server-only": "^0.0.1",
        "si-encryption": "github:safeinsights/encryption#0e892f0f38e8e92182fcf81d22c1760839e1d624",
        "uuid": "^14.0.0",
        "validator": "^13.15.26",
        "yjs": "^13.6.30",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@clerk/testing": "^1.14.7",
        "@eslint/js": "^9.39.2",
        "@ladle/react": "^5.1.1",
        "@next/eslint-plugin-next": "16.1.6",
        "@octokit/rest": "^22.0.1",
        "@pandacss/dev": "^1.8.2",
        "@playwright/test": "^1.58",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3",
        "@testing-library/user-event": "^14.6.1",
        "@types/debug": "^4.1.12",
        "@types/minimist": "^1.2.5",
        "@types/prompts": "^2.4.9",
        "@types/react": "19.2.14",
        "@vitejs/plugin-react": "^5.1.4",
        "aws-sdk-client-mock": "^4.1.0",
        "concurrently": "^10.0.3",
        "dotenv": "*",
        "esbuild": "^0.28.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "*",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-anti-trojan-source": "^1.1.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "globals": "^17.4.0",
        "happy-dom": "*",
        "husky": "^9.1.7",
        "kysely-codegen": "^0.20.0",
        "lint-staged": "^16.3.1",
        "minimist": "^1.2.8",
        "monocart-coverage-reports": "^2.12.11",
        "monocart-reporter": "^2.10.0",
        "next-router-mock": "^1.0.5",
        "pg-transactional-tests": "^1.2.0",
        "prettier": "*",
        "prompts": "^2.4.2",
        "tsx": "4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": ">=8.0.0",
        "vite-plugin-singlefile": "^2.3.3",
        "vitest": ">=4.1.6",
        "vitest-monocart-coverage": "^4.0.1"
    }
}
