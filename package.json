{
    "name": "management-app",
    "version": "0.0.1",
    "private": true,
    "description": "The SafeInsights management app serves as an interface for researchers to submit and reviewers to approve study proposals.",
    "license": "AGPL-3.0-or-later",
    "author": "Nathan Stitt",
    "main": "index.js",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build:app": "./bin/build-app",
        "build:editor": "./services/editor/build",
        "ci:server": "./bin/ci-server",
        "dev": "next dev -p 4000",
        "dev:local": "concurrently --kill-others-on-fail npm:dev npm:s3:local",
        "hocuspocus": "node services/editor/server.ts",
        "s3:local": "./bin/local-seaweedfs",
        "prepare": "panda codegen",
        "build": "next build",
        "db:migrate": "NODE_OPTIONS='--conditions=react-server' ./bin/migrate-dev-db",
        "create-admin-user": "NODE_OPTIONS='--conditions=react-server' tsx bin/create-admin-user.ts",
        "start": "next start",
        "deploy": "NODE_OPTIONS='--conditions=react-server' tsx bin/deploy.ts",
        "lint": "eslint . && prettier --check --log-level warn .",
        "validate-actions": "NODE_OPTIONS='--conditions=react-server' tsx tests/validate-actions.ts",
        "lint:fix": "eslint --fix . && prettier --write --log-level warn .",
        "pre:push": "concurrently --kill-others-on-fail 'npm:lint:fix' 'npm:typecheck' 'npm:validate-actions'",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "update-db-types": "NODE_OPTIONS='--conditions=react-server' kysely-codegen --camel-case --out-file src/database/types.ts",
        "checks": "concurrently 'npm:typecheck' 'npm:lint' 'npm:validate-actions'",
        "test:e2e": "playwright test",
        "test:e2e:debug": "playwright test --ui --headed --debug",
        "test:unit": "vitest",
        "test": "concurrently 'npm:test:*'",
        "test:coverage": "tsx tests/merged-coverage.ts",
        "pre:commit": "npx lint-staged",
        "update-all-packages": "npx npm-check-updates -u"
    },
    "dependencies": {
        "@aws-sdk/client-codebuild": "^3.893.0",
        "@aws-sdk/client-ecr": "^3.893.0",
        "@aws-sdk/client-glue": "^3.893.0",
        "@aws-sdk/client-s3": "^3.893.0",
        "@aws-sdk/client-secrets-manager": "^3.893.0",
        "@aws-sdk/client-sts": "^3.893.0",
        "@aws-sdk/credential-providers": "^3.893.0",
        "@aws-sdk/lib-storage": "^3.893.0",
        "@aws-sdk/rds-signer": "^3.893.0",
        "@aws-sdk/s3-presigned-post": "^3.893.0",
        "@aws-sdk/s3-request-presigner": "^3.893.0",
        "@casl/ability": "^6.8.0",
        "@clerk/nextjs": "^6.39.0",
        "@faker-js/faker": "^10.3.0",
        "@hocuspocus/provider": "^3.4.4",
        "@hocuspocus/server": "^3.4.4",
        "@lexical/link": "^0.41.0",
        "@lexical/list": "^0.41.0",
        "@lexical/react": "^0.41.0",
        "@mantine/core": "^8.3",
        "@mantine/dropzone": "^8.3",
        "@mantine/form": "^8.3",
        "@mantine/modals": "^8.3",
        "@mantine/notifications": "^8.3",
        "@phosphor-icons/react": "^2.1.10",
        "@sentry/nextjs": "^10.41.0",
        "@tanstack/react-query": "^5.90.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/papaparse": "^5.5.2",
        "aws-iam-policy-types": "^1.0.2",
        "child_process": "^1.0.2",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.19",
        "debug": "^4.4.3",
        "eventsource-parser": "^3.0.6",
        "highlight.js": "^11.11.1",
        "jsonwebtoken": "^9.0.3",
        "jws": "^4.0.1",
        "kysely": "^0.28.12",
        "kysely-ctl": "^0.20.0",
        "lexical": "^0.41.0",
        "libphonenumber-js": "^1.12.38",
        "mailgun.js": "^12.7.0",
        "mantine-datatable": "^8.3.13",
        "mantine-form-zod-resolver": "^1.3.0",
        "next": "^16.2.0",
        "next-swagger-doc": "^0.4.1",
        "papaparse": "^5.5.3",
        "pg": "^8.19.0",
        "qrcode.react": "^4.2.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-icons": "^5.5.0",
        "react-phone-number-input": "^3.4.16",
        "remeda": "^2.33.6",
        "server-only": "^0.0.1",
        "si-encryption": "github:safeinsights/encryption#2e35d3bb56f02bfc0e6d5cd9d83c54637ed0ac20",
        "uuid": "^13.0.0",
        "validator": "^13.15.26",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@clerk/testing": "^1.14.3",
        "@eslint/js": "^9.39.2",
        "@next/eslint-plugin-next": "16.1.6",
        "@octokit/rest": "^22.0.1",
        "@pandacss/dev": "^1.8.2",
        "@playwright/test": "^1.58",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3",
        "@testing-library/user-event": "^14.6.1",
        "@types/debug": "^4.1.12",
        "@types/minimist": "^1.2.5",
        "@types/prompts": "^2.4.9",
        "@types/react": "19.2.14",
        "@vitejs/plugin-react": "^5.1.4",
        "aws-sdk-client-mock": "^4.1.0",
        "concurrently": "^9.2.1",
        "dotenv": "*",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "*",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.4.0",
        "happy-dom": "*",
        "husky": "^9.1.7",
        "kysely-codegen": "^0.20.0",
        "lint-staged": "^16.3.1",
        "minimist": "^1.2.8",
        "monocart-reporter": "^2.10.0",
        "next-router-mock": "^1.0.5",
        "pg-transactional-tests": "^1.2.0",
        "prettier": "*",
        "prompts": "^2.4.2",
        "tsx": "4.21.0",
        "typescript-eslint": "^8.56.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "*",
        "vitest-monocart-coverage": "^4.0.1"
    },
    "overrides": {
        "@types/react": "19.2.14",
        "minimatch": "^10.2.1",
        "fast-xml-parser": "^5.3.8",
        "serialize-javascript": "^7.0.3",
        "express-rate-limit": "^8.2.2",
        "flatted": "^3.4.0",
        "nodemailer": "^8.0.4",
        "picomatch": "^4.0.4"
    }
}
