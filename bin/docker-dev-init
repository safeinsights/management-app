#!/bin/bash

# this file is the entrypoint for the Dockerfile.dev
# and is used for local development

set -e

# CI=true lets pnpm auto-purge a stale node_modules volume (e.g. after a lockfile change)
# without a TTY prompt — the container is non-interactive, so the prompt would otherwise
# abort the install and crash-loop. Scoped to install so it doesn't affect `pnpm run dev`.
CI=true pnpm install --frozen-lockfile

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

$SCRIPT_DIR/migrate-dev-db

pnpm run dev
