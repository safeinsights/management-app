#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

AWS_ACCOUNT_ID="${AWS_ACCOUNT_ID:?AWS_ACCOUNT_ID must be set}"
AWS_REGION="${AWS_REGION:-us-east-1}"
ECR_REPO="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/editor-service"

docker buildx build \
    --platform linux/amd64 \
    -f "$PROJECT_DIR/Dockerfile.editor-service" \
    -t "$ECR_REPO:latest" \
    --push \
    "$PROJECT_DIR"
