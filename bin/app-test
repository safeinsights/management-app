#!/usr/bin/env bash
#
# Build the management-app once and serve the prebuilt standalone server on the test
# port (4100) for the Playwright e2e stack. We do NOT use `next dev`: its lazy per-route
# compilation makes navigations take seconds and is unstable under the suite (tests
# exceed their timeout whether run in parallel or serially). A prebuilt server has no
# compilation cost — it's both fast and deterministic, and mirrors how CI runs
# (bin/ci-server).
#
# E2E_FAKE_CLERK aliases @clerk/nextjs[/server] to the in-app fake (src/lib/clerk-fake)
# at BUILD time — it must be set for `next build`, not just at server start. CI=true makes
# the server behave like CI (skips the prod-only Mailgun guard, disables Coder).
# SINGLE_USER_EDITING renders the standalone editor (no hocuspocus websocket).
#
# Usage: ./bin/app-test [--no-build]   (--no-build reuses an existing .next build)
#
# Driven by playwright.config.ts `webServer`. Kept separate from `dev` so local dev
# (port 4000, real Clerk, next dev) is untouched.

set -euo pipefail

cd "$(dirname "$0")/.."

# next build/start don't auto-load .env.test — load it explicitly.
if [ -f .env.test ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env.test
    set +a
fi

export CI=true
export E2E_FAKE_CLERK=1
export SINGLE_USER_EDITING=t
export PORT=4100
export ASSETS_PREFIX=/
export CODER_FILES=./coder-files
# .env.test sets AWS_PROFILE, which makes the AWS SDK prefer (expired) SSO over the static
# local-S3 creds — S3 calls then hang ~30s and time out the upload-heavy specs. Drop it so
# the static AWS_ACCESS_KEY_ID/SECRET (SeaweedFS) are used, matching CI.
unset AWS_PROFILE
# ClerkProvider guards on a publishable key being present; the fake ignores its value, so
# a dummy pk_test key satisfies the guard if .env.test doesn't provide one.
export NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:-pk_test_ZHVtbXktZm9yLWUyZS5jbGVyay5hY2NvdW50cy5kZXYk}"

if [ "${1:-}" != "--no-build" ]; then
    echo "app-test: building (E2E_FAKE_CLERK=1)…"
    env -u AWS_PROFILE pnpm exec next build
fi

# output: 'standalone' means the runnable server is .next/standalone/server.js; copy the
# static assets next to it the way bin/ci-server does.
cp -r public .next/standalone/ 2>/dev/null || true
mkdir -p .next/standalone/coder-files
cp -r .next/static .next/standalone/.next/ 2>/dev/null || true

echo "app-test: starting standalone server on :4100 (CI=true, E2E_FAKE_CLERK=1, SINGLE_USER_EDITING=t)"
exec node .next/standalone/server.js
