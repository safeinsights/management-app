#!/usr/bin/env bash
#
# Boot the clerk-stub (testing-only Clerk impostor) for the Playwright e2e stack.
# Driven by playwright.config.ts `webServer` (health-checked at https://localhost:4040/health).
#
# clerk-stub is NOT part of local dev (`dev:local` / docker-compose stay on real Clerk).
# It lives in a sibling checkout so we can patch wire-shape gaps directly:
#   git clone https://github.com/safeinsights/clerk-stub ../clerk-stub
#
# Prerequisites handled here: sibling checkout present, deps installed, mkcert TLS
# cert generated. The host must have run `mkcert -install` once (CA trust).

set -euo pipefail

STUB_DIR="${CLERK_STUB_DIR:-$(cd "$(dirname "$0")/../.." && pwd)/clerk-stub}"
# The app and FAPI run on sibling subdomains of lvh.me (which resolves to 127.0.0.1) so
# the session cookie can be shared via Domain=.lvh.me — browsers reject Domain=localhost,
# and clerk.<host> on a bare host can't share cookies with the app's host.
FAPI_HOST="${E2E_FAPI_HOST:-clerk.lvh.me:4040}"
APP_HOST="${E2E_APP_HOST:-app.lvh.me:4100}"

if [ ! -d "$STUB_DIR" ]; then
    echo "ERROR: clerk-stub not found at $STUB_DIR" >&2
    echo "Clone it as a sibling of management-app:" >&2
    echo "  git clone https://github.com/safeinsights/clerk-stub $STUB_DIR" >&2
    exit 1
fi

if ! command -v mkcert >/dev/null 2>&1; then
    echo "ERROR: mkcert is required for clerk-stub TLS. Install it and trust the CA:" >&2
    echo "  brew install mkcert nss && mkcert -install" >&2
    exit 1
fi

cd "$STUB_DIR"

if [ ! -d node_modules ]; then
    echo "clerk-stub: installing deps (first run)…"
    npm install
fi

FAPI_HOSTNAME="${FAPI_HOST%%:*}" # strip :port -> clerk.lvh.me

# The stub refuses to start without a TLS cert. Issue a leaf covering the FAPI host
# (clerk.lvh.me — must contain a dot for @clerk/shared) plus localhost/127.0.0.1.
CERT="data/tls/localhost.pem"
KEY="data/tls/localhost-key.pem"
if [ ! -f "$CERT" ] || [ ! -f "$KEY" ]; then
    echo "clerk-stub: generating mkcert TLS cert (${FAPI_HOSTNAME} + localhost)…"
    mkdir -p data/tls
    mkcert -cert-file "$CERT" -key-file "$KEY" "$FAPI_HOSTNAME" localhost 127.0.0.1
fi

export PORT="${FAPI_HOST##*:}" # 4040
# Bind dual-stack (::) so the stub answers whether a client reaches the host via IPv6 or IPv4.
export HOST=::
export FAPI_HOST
# Dev mode (pk_test). clerk-js bootstraps fully against the stub in dev mode (the
# production bootstrap hangs). The dev-browser handshake is implemented in the stub.
export PK_INSTANCE_TYPE="${PK_INSTANCE_TYPE:-test}"
# Share the session cookie across clerk.lvh.me (FAPI) and app.lvh.me (app) via the parent.
export COOKIE_DOMAIN="${E2E_COOKIE_DOMAIN:-.lvh.me}"
# Fetch clerk.browser.js from jsdelivr — CI/sandboxes often can't resolve js.clerk.com.
export CLERK_JS_CDN="${CLERK_JS_CDN:-https://cdn.jsdelivr.net}"
export MGMNT_APP_URL="http://${APP_HOST}"
export AUTHORIZED_PARTIES="http://${APP_HOST},https://${FAPI_HOST}"
# Long session so a storageState captured in auth.setup survives the whole run.
export SESSION_TTL_SECONDS="${SESSION_TTL_SECONDS:-604800}"

echo "clerk-stub: starting on https://${FAPI_HOST} (app=${MGMNT_APP_URL}, cookieDomain=${COOKIE_DOMAIN})"
exec npm start
