#!/usr/bin/env bash
set -euo pipefail

# Bundle the SQS worker handler into worker.js for AWS Lambda.
# @aws-sdk/* is provided by the Node20 runtime; everything else is inlined.
# Alias @sentry/nextjs -> @sentry/node because the nextjs build is webpack-only;
# worker never calls Sentry.init, so the SDK stays inert (CloudWatch handles logs).

OUT_DIR=".next/worker"
rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

./node_modules/.bin/esbuild \
    src/server/agents/review-agent/worker.ts \
    --bundle \
    --platform=node \
    --target=node20 \
    --format=cjs \
    --outfile="$OUT_DIR/worker.js" \
    --external:@aws-sdk/* \
    --alias:@sentry/nextjs=@sentry/node \
    --tsconfig=tsconfig.json \
    --sourcemap=linked \
    --log-level=warning

pushd "$OUT_DIR" > /dev/null
zip -q -r ../../lambda-worker-package.zip .
popd > /dev/null

echo "Built lambda-worker-package.zip"
