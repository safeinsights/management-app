#!/usr/bin/env bash
set -euo pipefail

# Bundle the SQS worker handler into a single self-contained worker.js for AWS Lambda.
# @aws-sdk/* is provided by the Node20 Lambda runtime; everything else is inlined.

OUT_DIR=".next/worker"
rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

./node_modules/.bin/esbuild \
    src/server/workers/review-worker.ts \
    --bundle \
    --platform=node \
    --target=node20 \
    --format=cjs \
    --outfile="$OUT_DIR/worker.js" \
    --external:@aws-sdk/* \
    --external:@sentry/nextjs \
    --external:next \
    --tsconfig=tsconfig.json \
    --log-level=warning

# @sentry/nextjs is webpack-instrumented and not Node-Lambda-safe; stub it.
# Worker logger falls back to console for warn/error, which is what we want in Lambda.
mkdir -p "$OUT_DIR/node_modules/@sentry/nextjs"
cat > "$OUT_DIR/node_modules/@sentry/nextjs/index.js" <<'EOF'
exports.captureException = () => {}
exports.captureMessage = () => {}
exports.addBreadcrumb = () => {}
exports.withScope = (fn) => fn({ setExtras: () => {} })
EOF
cat > "$OUT_DIR/node_modules/@sentry/nextjs/package.json" <<'EOF'
{ "name": "@sentry/nextjs", "main": "index.js" }
EOF

pushd "$OUT_DIR" > /dev/null
zip -q -r ../../lambda-worker-package.zip .
popd > /dev/null

echo "Built lambda-worker-package.zip"
