#!/usr/bin/env bash
set -euo pipefail

# Bundle the SQS worker handler into a single self-contained worker.js for AWS Lambda.
# @aws-sdk/* is provided by the Node20 Lambda runtime; everything else is inlined.
#
# Logger imports `@sentry/nextjs`, which is webpack-instrumented and not bundleable
# by esbuild. Alias it to `@sentry/node`, which exposes the same surface
# (captureException, captureMessage, withScope, etc.) and bundles cleanly.

OUT_DIR=".next/worker"
rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

./node_modules/.bin/esbuild \
    src/server/workers/review-worker.ts \
    --bundle \
    --platform=node \
    --target=node20 \
    --format=cjs \
    --outfile="$OUT_DIR/worker.js" \
    --external:@aws-sdk/* \
    --alias:@sentry/nextjs=@sentry/node \
    --tsconfig=tsconfig.json \
    --log-level=warning

pushd "$OUT_DIR" > /dev/null
zip -q -r ../../lambda-worker-package.zip .
popd > /dev/null

echo "Built lambda-worker-package.zip"
