#!/bin/sh

set -e

export ASSETS_PREFIX=/
export PORT=4100
export CODER_FILES=./coder-files

# E2E runs against the in-app Clerk fake (src/lib/clerk-fake): no real Clerk server, no
# editor-service. E2E_FAKE_CLERK must be set for `pnpm run build` so the fake is aliased in
# at build time; SINGLE_USER_EDITING renders the standalone editor (no hocuspocus).
export E2E_FAKE_CLERK=1
export SINGLE_USER_EDITING=t
# ClerkProvider guards on a publishable key being present; the fake ignores its value.
export NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY:-pk_test_ZHVtbXktZm9yLWUyZS5jbGVyay5hY2NvdW50cy5kZXYk}"

LOG=$1

if [ -z "$LOG" ]; then
    echo "Usage: $0 <logfile>"
    exit 1
fi

pnpm run build > $LOG 2>&1

cp -r public .next/standalone/
mkdir -p .next/standalone/coder-files
cp -r .next/static .next/standalone/.next/

node .next/standalone/server.js >> $LOG 2>&1 &
SERVER_PID=$!

echo "starting in background with pid $SERVER_PID"
echo "process name will be: next-server"

echo "waiting for server to be reachable..."
for i in $(seq 1 5); do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:4100/ 2>/dev/null | grep -q '^[23]'; then
        echo "server is reachable on localhost:4100 (attempt $i)"
        break
    fi
    if curl -s -o /dev/null -w "%{http_code}" http://127.0.0.1:4100/ 2>/dev/null | grep -q '^[23]'; then
        echo "server is reachable on 127.0.0.1:4100 (attempt $i)"
        break
    fi
    if [ $i -eq 3 ]; then
        echo "ERROR: server not reachable after 3 attempts"
        echo "--- netstat ---"
        ss -tlnp | grep 4100 || true
        echo "--- curl localhost ---"
        curl -v http://localhost:4100/ 2>&1 || true
        echo "--- curl 127.0.0.1 ---"
        curl -v http://127.0.0.1:4100/ 2>&1 || true
        echo "--- server log ---"
        tail -20 $LOG || true
        exit 1
    fi
    sleep 2
done
