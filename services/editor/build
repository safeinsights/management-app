#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"

: "${DOCKER_REPO:?DOCKER_REPO must be set}"
: "${DOCKER_TAG:=latest}"

docker buildx build \
    --platform linux/amd64 \
    -f "$PROJECT_DIR/Dockerfile.editor-service" \
    -t "$DOCKER_REPO:$DOCKER_TAG" \
    "$PROJECT_DIR"
