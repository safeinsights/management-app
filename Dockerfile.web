# Web Lambda container image. Replaces the previous lambda-server-package.zip.
# Same Next.js standalone server, just packaged as a container with the
# Lambda Web Adapter as an extension instead of a Lambda layer.

FROM node:20-slim

# Lambda Web Adapter runs as a Lambda extension — auto-starts, forwards HTTP
# from the Lambda invoke event (Function URL / API Gateway) to the long-running
# Node HTTP server. Same role the Web Adapter Layer played in the zip Lambda.
COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:0.8.4 /lambda-adapter /opt/extensions/lambda-adapter

# Adapter config. PORT must match where prod.run.sh starts Next standalone.
ENV PORT=8080
ENV AWS_LWA_PORT=8080
ENV AWS_LWA_READINESS_CHECK_PATH=/

# Tiny tool used by prod.run.sh to call Secrets Manager at cold-start.
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /var/task

# Next.js standalone bundle includes traced node_modules — no separate install step.
COPY .next/standalone/ /var/task/
COPY .next/static /var/task/.next/static
COPY public /var/task/public

# Entrypoint fetches DB + app secrets at cold-start, then exec's `node server.js`.
COPY bin/prod.run.sh /var/task/run.sh
RUN chmod +x /var/task/run.sh

CMD ["./run.sh"]
